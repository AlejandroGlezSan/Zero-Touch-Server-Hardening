# =================================================================
# Vagrantfile - Fortress Hardening Lab (Linux)
# Autor: Alejandro González Santana
# Descripción: Entorno de pruebas aislado para fortress_hardening.sh
#              Ejecuta el hardening y valida los resultados automáticamente.
# Uso:
#   vagrant up            → levanta la VM, aplica hardening y ejecuta tests
#   vagrant up --provision → re-ejecuta provisión en VM existente
#   vagrant ssh           → accede a la VM para inspección manual
#   vagrant destroy -f    → elimina la VM completamente
# =================================================================

Vagrant.configure("2") do |config|

  # ── Box base ────────────────────────────────────────────────────
  config.vm.box     = "ubuntu/focal64"
  config.vm.hostname = "fortress-lab"

  # ── Recursos ────────────────────────────────────────────────────
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "2048"
    vb.cpus   = 2
    vb.name   = "Fortress_Hardening_Lab"
    # Deshabilitar audio y USB (reduce superficie de ataque y acelera boot)
    vb.customize ["modifyvm", :id, "--audio",    "none"]
    vb.customize ["modifyvm", :id, "--usb",      "off"]
    vb.customize ["modifyvm", :id, "--usbehci",  "off"]
  end

  # ── Red: solo loopback + NAT (sin red host-only expuesta) ────────
  # La VM no expone puertos al host por defecto, todo es interno.
  # Descomenta la siguiente línea si necesitas acceder a servicios desde el host:
  # config.vm.network "forwarded_port", guest: 22, host: 2222, id: "ssh"

  # ── Carpeta compartida ───────────────────────────────────────────
  # Monta la carpeta actual (donde está el Vagrantfile) en /vagrant dentro de la VM.
  # Copia aquí fortress_hardening.sh antes de hacer vagrant up.
  config.vm.synced_folder ".", "/vagrant"

  # ── Paso 1: Preparación del entorno ─────────────────────────────
  config.vm.provision "shell", name: "01-prepare", inline: <<-SHELL
    set -e
    echo ""
    echo "════════════════════════════════════════════════════"
    echo " FORTRESS HARDENING LAB - Preparación del entorno"
    echo "════════════════════════════════════════════════════"

    # Verificar que el script existe en la carpeta compartida
    if [ ! -f /vagrant/fortress_hardening.sh ]; then
      echo "[ERROR] No se encontró /vagrant/fortress_hardening.sh"
      echo "        Copia el script a la misma carpeta que este Vagrantfile."
      exit 1
    fi

    # Dependencias mínimas para el entorno de pruebas
    apt-get update -qq
    apt-get install -y -qq dos2unix curl net-tools bc 2>/dev/null

    # Normalizar el script (eliminar CRLF si viene de Windows)
    dos2unix /vagrant/fortress_hardening.sh 2>/dev/null
    chmod +x /vagrant/fortress_hardening.sh

    echo "[OK] Entorno preparado."
  SHELL

  # ── Paso 2: Ejecución del hardening ─────────────────────────────
  config.vm.provision "shell", name: "02-hardening", inline: <<-SHELL
    set -e
    echo ""
    echo "════════════════════════════════════════════════════"
    echo " FORTRESS HARDENING LAB - Aplicando hardening..."
    echo "════════════════════════════════════════════════════"

    sudo /bin/bash /vagrant/fortress_hardening.sh
    echo "[OK] Script de hardening finalizado."
  SHELL

  # ── Paso 3: Tests automatizados de verificación ─────────────────
  config.vm.provision "shell", name: "03-tests", privileged: true, inline: <<-'SHELL'
    # ── Colores ──────────────────────────────────────────────────
    GREEN='\033[0;32m'
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'
    NC='\033[0m'

    PASS=0
    FAIL=0
    WARN=0

    pass() { echo -e "  ${GREEN}[PASS]${NC} $1"; PASS=$((PASS+1)); }
    fail() { echo -e "  ${RED}[FAIL]${NC} $1"; FAIL=$((FAIL+1)); }
    warn() { echo -e "  ${YELLOW}[WARN]${NC} $1"; WARN=$((WARN+1)); }
    section() {
      echo ""
      echo -e "${CYAN}▶ $1${NC}"
      echo "  ──────────────────────────────────────────────"
    }

    echo ""
    echo "════════════════════════════════════════════════════"
    echo " FORTRESS HARDENING LAB - Suite de tests"
    echo "════════════════════════════════════════════════════"

    # ── TEST 1: Paquetes instalados ───────────────────────────────
    section "Paquetes de seguridad"
    for pkg in fail2ban ufw clamav clamav-daemon unattended-upgrades auditd; do
      if dpkg -l "$pkg" 2>/dev/null | grep -q "^ii"; then
        pass "$pkg instalado"
      else
        fail "$pkg NO instalado"
      fi
    done

    # ── TEST 2: Servicios activos ─────────────────────────────────
    section "Servicios activos"
    for svc in fail2ban ufw auditd clamav-freshclam; do
      if systemctl is-active --quiet "$svc" 2>/dev/null; then
        pass "$svc activo"
      else
        fail "$svc NO está activo"
      fi
    done

    # ── TEST 3: Firewall UFW ──────────────────────────────────────
    section "Firewall UFW"
    if ufw status | grep -q "Status: active"; then
      pass "UFW activo"
    else
      fail "UFW inactivo"
    fi
    if ufw status | grep -qE "^22(/tcp)?[[:space:]]+ALLOW"; then
      pass "Puerto SSH (22) permitido"
    else
      fail "Puerto SSH (22) no encontrado en reglas UFW"
    fi
    if ufw status verbose | grep -q "Default: deny (incoming)"; then
      pass "Política por defecto: DENY incoming"
    else
      fail "Política incoming no es DENY"
    fi

    # ── TEST 4: Hardening SSH ─────────────────────────────────────
    section "Configuración SSH"
    sshd_cfg="/etc/ssh/sshd_config"

    check_sshd() {
      local directive="$1"
      local expected="$2"
      local value
      value=$(/usr/sbin/sshd -T 2>/dev/null | grep -i "^${directive} " | awk '{print $2}')
      if echo "$value" | grep -qi "$expected"; then
        pass "$directive = $value"
      else
        fail "$directive = '$value' (esperado: $expected)"
      fi
    }

    check_sshd "permitrootlogin"           "no"
    check_sshd "passwordauthentication"    "no"
    check_sshd "x11forwarding"             "no"
    check_sshd "maxauthtries"              "3"
    check_sshd "clientaliveinterval"       "300"
    check_sshd "permitemptypasswords"      "no"
    check_sshd "allowtcpforwarding"        "no"

    # Verificar cifrados modernos
    if grep -q "^KexAlgorithms" "$sshd_cfg"; then
      pass "KexAlgorithms configurados explícitamente"
    else
      fail "KexAlgorithms NO configurados"
    fi
    if grep -q "^Ciphers" "$sshd_cfg"; then
      pass "Ciphers configurados explícitamente"
    else
      fail "Ciphers NO configurados"
    fi
    if grep -q "^MACs" "$sshd_cfg"; then
      pass "MACs configurados explícitamente"
    else
      fail "MACs NO configurados"
    fi
    # Verificar ausencia de cifrados débiles en la configuración
    if ! /usr/sbin/sshd -T 2>/dev/null | grep -i "ciphers" | grep -qi "arcfour\|3des\|blowfish"; then
      pass "Sin cifrados débiles en SSH (arcfour, 3des, blowfish)"
    else
      fail "Cifrados débiles detectados en SSH"
    fi

    # ── TEST 5: Fail2Ban ──────────────────────────────────────────
    section "Fail2Ban"
    if [ -f /etc/fail2ban/jail.local ]; then
      pass "jail.local existe"
    else
      fail "jail.local NO existe"
    fi
    if fail2ban-client status sshd 2>/dev/null | grep -q "Status for"; then
      pass "Jail sshd activo en Fail2Ban"
    else
      fail "Jail sshd NO activo en Fail2Ban"
    fi
    if fail2ban-client status recidive 2>/dev/null | grep -q "Status for"; then
      pass "Jail recidive activo en Fail2Ban"
    else
      warn "Jail recidive no activo (puede necesitar tiempo)"
    fi

    # ── TEST 6: Parámetros del kernel (sysctl) ────────────────────
    section "Hardening del kernel (sysctl)"
    check_sysctl() {
      local param="$1"
      local expected="$2"
      local value
      value=$(sysctl -n "$param" 2>/dev/null)
      if [ "$value" = "$expected" ]; then
        pass "$param = $value"
      else
        fail "$param = '$value' (esperado: $expected)"
      fi
    }

    check_sysctl "net.ipv4.conf.all.rp_filter"               "1"
    check_sysctl "net.ipv4.conf.all.accept_redirects"        "0"
    check_sysctl "net.ipv4.conf.all.send_redirects"          "0"
    check_sysctl "net.ipv4.tcp_syncookies"                   "1"
    check_sysctl "net.ipv4.conf.all.accept_source_route"     "0"
    check_sysctl "net.ipv4.conf.all.log_martians"            "1"
    check_sysctl "net.ipv4.icmp_echo_ignore_broadcasts"      "1"

    # ── TEST 7: Permisos de archivos críticos ─────────────────────
    section "Permisos de archivos críticos"
    check_perm() {
      local file="$1"
      local expected_octal="$2"
      if [ -f "$file" ]; then
        local perm
        perm=$(stat -c "%a" "$file")
        if [ "$perm" = "$expected_octal" ]; then
          pass "$file → $perm"
        else
          fail "$file → $perm (esperado: $expected_octal)"
        fi
      else
        warn "$file no encontrado"
      fi
    }

    check_perm "/etc/shadow"  "600"
    check_perm "/etc/gshadow" "600"
    check_perm "/etc/passwd"  "644"
    check_perm "/etc/group"   "644"

    # ── TEST 8: Actualizaciones automáticas ───────────────────────
    section "Actualizaciones automáticas"
    if [ -f /etc/apt/apt.conf.d/50unattended-upgrades ]; then
      pass "50unattended-upgrades configurado"
    else
      fail "50unattended-upgrades NO encontrado"
    fi
    if [ -f /etc/apt/apt.conf.d/20auto-upgrades ]; then
      pass "20auto-upgrades configurado"
    else
      fail "20auto-upgrades NO encontrado"
    fi

    # ── TEST 9: auditd ────────────────────────────────────────────
    section "Auditoría del sistema (auditd)"
    if systemctl is-active --quiet auditd; then
      pass "auditd corriendo"
    else
      fail "auditd NO está corriendo"
    fi
    if [ -f /etc/audit/rules.d/99-hardening.rules ]; then
      pass "Reglas de auditoría 99-hardening.rules presentes"
    else
      fail "Reglas de auditoría NO encontradas"
    fi
    if auditctl -l 2>/dev/null | grep -q "sudoers"; then
      pass "Regla de auditoría para sudoers activa"
    else
      warn "Regla para sudoers no cargada aún (puede requerir reinicio)"
    fi

    # ── TEST 10: sudo hardening ───────────────────────────────────
    section "Hardening de sudo"
    if grep -q "log_output" /etc/sudoers 2>/dev/null; then
      pass "sudoers: log_output configurado"
    else
      fail "sudoers: log_output NO configurado"
    fi
    if grep -q "requiretty" /etc/sudoers 2>/dev/null; then
      pass "sudoers: requiretty configurado"
    else
      fail "sudoers: requiretty NO configurado"
    fi

    # ── TEST 11: ClamAV ───────────────────────────────────────────
    section "ClamAV"
    if [ -f /usr/local/bin/clamav_daily_scan.sh ]; then
      pass "Script de escaneo diario creado"
    else
      fail "Script de escaneo diario NO encontrado"
    fi
    if [ -f /etc/cron.d/clamav_daily ]; then
      pass "Cron de ClamAV configurado"
    else
      fail "Cron de ClamAV NO configurado"
    fi

    # ── TEST 12: Backup generado ──────────────────────────────────
    section "Backup de configuraciones"
    if ls /root/hardening_backup_* 2>/dev/null | head -1 | grep -q "hardening_backup"; then
      backup=$(ls -d /root/hardening_backup_* 2>/dev/null | tail -1)
      pass "Backup creado en: $backup"
      [ -d "$backup/ssh" ]    && pass "  Backup de SSH incluido"    || warn "  Backup de SSH no encontrado"
      [ -f "$backup/sysctl.conf" ] && pass "  Backup de sysctl incluido" || warn "  Backup de sysctl no encontrado"
    else
      fail "No se encontró directorio de backup"
    fi

    # ── Resumen final ─────────────────────────────────────────────
    TOTAL=$((PASS + FAIL + WARN))
    echo ""
    echo "════════════════════════════════════════════════════"
    echo -e " RESULTADOS FINALES   (total: $TOTAL tests)"
    echo "════════════════════════════════════════════════════"
    echo -e "  ${GREEN}PASS: $PASS${NC}"
    echo -e "  ${RED}FAIL: $FAIL${NC}"
    echo -e "  ${YELLOW}WARN: $WARN${NC}"
    echo "════════════════════════════════════════════════════"

    if [ "$FAIL" -eq 0 ]; then
      echo -e "  ${GREEN}✔ Hardening verificado correctamente.${NC}"
      exit 0
    else
      echo -e "  ${RED}✘ Se detectaron $FAIL fallos. Revisa el log en /var/log/fortress_hardening.log${NC}"
      exit 1
    fi
  SHELL

end